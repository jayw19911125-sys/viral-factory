  "segments": [
    {
      "start": 0,
      "end": 4.400000095367432,
      "text": "花生醬"
    },
    {
      "start": 4.400000095367432,
      "end": 5.099999904632568,
      "text": "嗨"
    },
    {
      "start": 5.099999904632568,
      "end": 6.400000095367432,
      "text": "哪尼嘎斯基"
    },
    {
      "start": 6.400000095367432,
      "end": 9.699999809265137,
      "text": "一杯香檳茶 還是最喜歡你"
    },
    {
      "start": 9.699999809265137,
      "end": 11.300000190734863,
      "text": "太閃很困擾 沒關係"
    },
    {
      "start": 11.300000190734863,
      "end": 14.300000190734863,
      "text": "這瓶甜椒膏吧 輕鬆喝 放輕鬆"
    },
    {
      "start": 14.300000190734863,
      "end": 15.800000190734863,
      "text": "我說我們要喝有糖的"
    },
    {
      "start": 15.800000190734863,
      "end": 17.600000381469727,
      "text": "一下減肥 一下又喝有糖的"
    },
    {
      "start": 17.600000381469727,
      "end": 18.299999237060547,
      "text": "現在怎樣"
    },
    {
      "start": 18.299999237060547,
      "end": 20.399999618530273,
      "text": "我壓力就很大 我想喝有糖"
    },
    {
      "start": 20.399999618530273,
      "end": 21.700000762939453,
      "text": "壓力大怎麼大 到時候"
    },
    {
      "start": 21.700000762939453,
      "end": 23.200000762939453,
      "text": "他們的情緒高糖高鈉"
    },
    {
      "start": 23.200000762939453,
      "end": 26.100000381469727,
      "text": "還好這瓶 零糖 零咖啡 零熱量"
    },
    {
      "start": 26.100000381469727,
      "end": 28.5,
      "text": "這應該要藍色配色才行吧"
    },
    {
      "start": 28.5,
      "end": 29.5,
      "text": "這不就很俗嗎"
    },
    {
      "start": 29.5,
      "end": 30.600000381469727,
      "text": "這樣真的不行"
    },
    {
      "start": 30.600000381469727,
      "end": 32.099998474121094,
      "text": "你都買單了 你管我"
    },
    {
      "start": 32.099998474121094,
      "end": 33,
      "text": "很醜"
    },
    {
      "start": 33,
      "end": 33.5,
      "text": "什麼醜"
    },
    {
      "start": 33.5,
      "end": 34,
      "text": "你才"
    },
    {
      "start": 34,
      "end": 35.400001525878906,
      "text": "色彩戰爭不關我的事"
    },
    {
      "start": 35.400001525878906,
      "end": 36.400001525878906,
      "text": "這瓶甜椒幹嘛"
    },
    {
      "start": 36.400001525878906,
      "end": 38.20000076293945,
      "text": "讓我直接進入淡定模式"
    },
    {
      "start": 38.20000076293945,
      "end": 40.599998474121094,
      "text": "No"
    },
    {
      "start": 40.599998474121094,
      "end": 42.70000076293945,
      "text": "Ria的Ria"
    },
    {
      "start": 42.70000076293945,
      "end": 44.099998474121094,
      "text": "你為什麼答應老闆說要加班"
    },
    {
      "start": 44.099998474121094,
      "end": 45.599998474121094,
      "text": "我們不是說好要去看阿湯哥嗎"
    },
    {
      "start": 45.599998474121094,
      "end": 46.599998474121094,
      "text": "我又不是故意的"
    },
    {
      "start": 46.599998474121094,
      "end": 47.599998474121094,
      "text": "我要鋪業績"
    },
    {
      "start": 47.599998474121094,
      "end": 48.400001525878906,
      "text": "阿湯哥不要這樣"
    },
    {
      "start": 48.400001525878906,
      "end": 50.20000076293945,
      "text": "No"
    },
    {
      "start": 50.20000076293945,
      "end": 50.900001525878906,
      "text": "熱鬧的歌"
    },
    {
      "start": 50.900001525878906,
      "end": 52.400001525878906,
      "text": "他們在吵什麼 我不知道"
    },
    {
      "start": 52.400001525878906,
      "end": 54.79999923706055,
      "text": "我只想喝零負擔的白茶"
    },
    {
      "start": 54.79999923706055,
      "end": 56.70000076293945,
      "text": "昨天都是我的錯 對不起"
    },
    {
      "start": 56.70000076293945,
      "end": 58.20000076293945,
      "text": "花生醬是最重要的"
    },
    {
      "start": 58.20000076293945,
      "end": 60.099998474121094,
      "text": "好了 下次要記得先問我"
    },
    {
      "start": 60.099998474121094,
      "end": 61.099998474121094,
      "text": "吃早餐"
    },
    {
      "start": 61.099998474121094,
      "end": 61.79999923706055,
      "text": "Yeah"
    }
